{
  "name": "@matt-tingen/eslint-config",
  "version": "0.16.0",
  "repository": "github:matt-tingen/eslint-config",
  "author": "Matt Tingen <matt.tingen@gmail.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --clean --dts --format esm,cjs",
    "ts": "tsc --noEmit",
    "lint": "eslint",
    "format": "prettier --write src",
    "preversion": "pnpm ts && pnpm lint && pnpm build",
    "postversion": "pnpm publish && git push && git push --tags"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@matt-tingen/util": "^3.3.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-config-flat-gitignore": "^2.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-type-only": "^1.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/utils": "^8.57.1",
    "eslint": "^9.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "eslint": "^9.22.0"
  }
}
